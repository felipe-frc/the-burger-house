{
  "name": "the-burger-house",
  "version": "1.7.0",
  "description": "Cardápio digital para hamburgueria com carrinho interativo, integração com WhatsApp e busca automática de endereço por CEP.",
  "author": "Felipe França",
  "license": "MIT",
  "scripts": {
    "dev": "tailwindcss -i ./styles/style.css -o ./output.css --watch",
    "build": "tailwindcss -i ./styles/style.css -o ./output.css --minify",
    "serve:e2e": "vite --host 127.0.0.1 --port 4173 --strictPort",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "npm run build && playwright test",
    "e2e:ci": "playwright test",
    "e2e:headed": "npm run build && playwright test --headed",
    "e2e:ui": "npm run build && playwright test --ui"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@vitest/coverage-v8": "^4.1.6",
    "jsdom": "^29.1.1",
    "tailwindcss": "^3.4.19",
    "vite": "^7.2.4",
    "vitest": "^4.1.6"
  }
}
